			<Method>
				<Name>init</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    public void init()
    {
        super();
    
        if (element.args() && element.args().record())
        {
            ATLCourseTable callerRecord = element.args().record();
        
            ATLCourseTable_ds.query()
            .dataSourceTable(tableNum(ATLCourseTable))
            .addRange(fieldNum(ATLCourseTable, CourseId))
            .value(callerRecord.CourseId);

            if (callerRecord.IsEnabled == NoYes::No)
            {
                ATLCourseTable_ds.allowEdit(false);
                ATLCourseTable_ds.allowCreate(false);
                ATLCourseTable_ds.allowDelete(false);
            }
        }
    }

]]></Source>
			</Method>
		</Methods>
		<DataSources xmlns="">
			<DataSource>
				<Name>ATLCourseTable</Name>
				<Methods>
					<Method>
						<Name>active</Name>
						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        /// <returns></returns>
        public int active()
        {
            int ret = super();
            ATLCourseTable currentRecord = ATLCourseTable_ds.cursor();
    
            if (currentRecord.IsEnabled == NoYes::No)
            {
                ATLCourseTable_ds.allowEdit(false);
                ATLCourseTable_ds.allowCreate(false);
                ATLCourseTable_ds.allowDelete(false);
            }
            else
            {
                ATLCourseTable_ds.allowEdit(true);
                ATLCourseTable_ds.allowCreate(true);
                ATLCourseTable_ds.allowDelete(true);
            }
    
            return ret;
        }

]]></Source>
					</Method>
				</Methods>
				<Fields />
			</DataSource>
