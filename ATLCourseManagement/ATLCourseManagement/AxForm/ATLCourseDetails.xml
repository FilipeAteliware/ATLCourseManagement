				<Methods>
					<Method>
						<Name>clicked</Name>
						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        public void clicked()
        {
            ATLCourseTable selectedCourse = ATLCourseTable_ds.cursor();

            Args args = new Args();
            args.record(selectedCourse);
            args.name(formStr(ATLCourseParticipantForm));
    
            new MenuFunction(
                menuItemDisplayStr(ATLCourseParticipantForm),
                MenuItemType::Display)
                .run(args);
    
            info(strFmt("CourseId selecionado: %1", selectedCourse.CourseId));
        }

]]></Source>
