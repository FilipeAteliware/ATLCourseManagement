    public void init()
    {
        super();
    
        if (element.args() && element.args().record())
        {
            ATLCourseTable callerRecord = element.args().record();
        
            ATLCourseParticipant_ds.query()
            .dataSourceTable(tableNum(ATLCourseParticipant))
            .addRange(fieldNum(ATLCourseParticipant, CourseId))
            .value(callerRecord.CourseId);

            if (callerRecord.IsEnabled == NoYes::No)
            {
                ATLCourseParticipant_ds.allowEdit(false);
                ATLCourseParticipant_ds.allowCreate(false);
                ATLCourseParticipant_ds.allowDelete(false);
            }
        }
    }

